{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RabbitMQ":{
    "Host" : "rabbitmq",
    "Port" : 5672,
    "VirtualHost" : "/",
    "Username" : "YOUR_RABBITMQ_USERNAME",
    "Password" : "YOUR_RABBITMQ_PASSWORD"
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=mysql;port=3306;database=trainee_management_db;user=YOUR_DATABASE_USERNAME;password=YOUR_DATABASE_PASSWORD;",
    "Redis": "redis:6379",
    "HttpClientAPI" : "http://traineedirectory-container:8080/api/"
  },
  "FileStorageService": {
    "Path": "./",
    "MaxSize": "5000000",
    "AllowedExtensions": [
      ".txt",
      ".pdf"
    ]
  }
}
